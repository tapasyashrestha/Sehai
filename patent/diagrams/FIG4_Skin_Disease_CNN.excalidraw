      "updated": 1700000000000,
      "link": null,
      "locked": false,
      "text": "ResNet18 BACKBONE  (skin_disease.pth  |  14-class output)\nConv1 (7×7, 64)  →  MaxPool  →  Layer1 (64ch)  →  Layer2 (128ch)\n→  Layer3 (256ch)  →  Layer4 (512ch)  →  Global Avg Pool  →  512-dim feature vector\nFC: nn.Linear(512, 14)   [modified from original 1000-class layer]",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "ResNet18 BACKBONE  (skin_disease.pth  |  14-class output)\nConv1 (7×7, 64)  →  MaxPool  →  Layer1 (64ch)  →  Layer2 (128ch)\n→  Layer3 (256ch)  →  Layer4 (512ch)  →  Global Avg Pool  →  512-dim feature vector\nFC: nn.Linear(512, 14)   [modified from original 1000-class layer]",
      "lineHeight": 1.25,
      "autoResize": true
    },
