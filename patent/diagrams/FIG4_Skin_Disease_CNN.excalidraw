      "link": null,
      "locked": false,
      "text": "IMAGE PREPROCESSING  (identical to FIG. 3 — shared _IMG_TRANSFORM)\n1. Image.open(io.BytesIO(bytes)).convert('RGB')\n2. Resize((224, 224))  →  ToTensor()  →  tensor shape: [3, 224, 224]\n3. Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "IMAGE PREPROCESSING  (identical to FIG. 3 — shared _IMG_TRANSFORM)\n1. Image.open(io.BytesIO(bytes)).convert('RGB')\n2. Resize((224, 224))  →  ToTensor()  →  tensor shape: [3, 224, 224]\n3. Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])",
      "lineHeight": 1.25,
      "autoResize": true
    },
